{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable",
            "cargo": {
                "args": [
                    "build",
                    "--bin",
                    "feathertail",
                    "--package",
                    "feathertail"
                ],
                "filter": {
                    "name": "feathertail",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin",
                    "feathertail",
                    "--package",
                    "feathertail"
                ],
                "filter": {
                    "name": "feathertail",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}
